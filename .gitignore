.idea/
__pycache__/
*.pyc
.pytest_cache/

lightning_logs/
logs/

# Stray Lightning default output
/checkpoints/

# Generated simulation (regenerate via scripts/01 or scripts/12)
data/sim/*.csv
data/sim/*.parquet

# Manuscript pipeline checkpoints
outputs/checkpoints/
